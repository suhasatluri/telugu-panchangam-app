# ─────────────────────────────────────────
# Telugu Panchangam App — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to git
# ─────────────────────────────────────────

# OpenCage Geocoding API
# Required for city search
# Get free key (2,500 req/day): https://opencagedata.com
OPENCAGE_API_KEY=your_opencage_key_here

# Resend Email API
# Required for ancestor reminder emails
# Get free key (3,000 emails/month): https://resend.com
RESEND_API_KEY=your_resend_key_here
RESEND_FROM_EMAIL=reminders@yourdomain.com

# Cron Worker Secret
# Required to protect /api/cron/send-reminders
# Generate: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
